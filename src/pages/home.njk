---
pagination:
  data: i18n.codes
  size: 1
  alias: lang
permalink: "/{{ lang }}/"
layout: base.njk
---

<main>
  <div class="fns-pixel-frame fns-pixel-frame--hero">
    <div class="fns-pixel-frame__inner">
      <div class="fns-wordmark" role="group" aria-label="{{ i18n[lang].wordmark.ariaLabel }}">
        {% if i18n[lang].wordmark.grayTop %}
        <p class="fns-wordmark__muted">{{ i18n[lang].wordmark.grayTop }}</p>
        {% endif %}
        <p class="fns-wordmark__main">{{ i18n[lang].wordmark.main }}</p>
        {% if i18n[lang].wordmark.grayBottom %}
        <p class="fns-wordmark__muted">{{ i18n[lang].wordmark.grayBottom }}</p>
        {% endif %}
      </div>
      <nav class="fns-social" aria-label="{{ i18n[lang].social.ariaLabel }}">
        <a
          class="fns-social__link"
          href="https://vk.com/forestnarrativesstudio"
          rel="noopener noreferrer"
          target="_blank"
          title="{{ i18n[lang].social.vk.label }}"
          aria-label="{{ i18n[lang].social.vk.label }}"
        >
          <img class="fns-social__icon" src="/assets/icons/vk.svg" width="40" height="40" alt="" />
        </a>
        <a
          class="fns-social__link"
          href="https://t.me/forestnarrativesstudio"
          rel="noopener noreferrer"
          target="_blank"
          title="{{ i18n[lang].social.telegram.label }}"
          aria-label="{{ i18n[lang].social.telegram.label }}"
        >
          <img class="fns-social__icon" src="/assets/icons/telegram.svg" width="40" height="40" alt="" />
        </a>
        <a
          class="fns-social__link"
          href="https://max.ru/join/YQzEQSTrjVDh0yNAw5lNeJrT2PIjKEwnPiTQJtTaCIM"
          rel="noopener noreferrer"
          target="_blank"
          title="{{ i18n[lang].social.max.label }}"
          aria-label="{{ i18n[lang].social.max.label }}"
        >
          <img class="fns-social__icon" src="/assets/icons/max.svg" width="40" height="40" alt="" />
        </a>
      </nav>
      <p class="fns-copyright">(c) 2023–2026</p>
    </div>
  </div>
</main>
