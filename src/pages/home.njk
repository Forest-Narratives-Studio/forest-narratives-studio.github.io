---
pagination:
  data: i18n.codes
  size: 1
  alias: lang
permalink: "/{{ lang }}/"
layout: base.njk
pageImage: "/assets/strange-house/og-strange-house.webp"
twitterCard: "summary_large_image"
---

<main>
  <div class="fns-pixel-frame fns-pixel-frame--hero">
    <div class="fns-pixel-frame__inner">
      <div class="fns-wordmark" role="group" aria-label="{{ i18n[lang].wordmark.ariaLabel }}">
        {% if i18n[lang].wordmark.grayTop %}
        <p class="fns-wordmark__muted">{{ i18n[lang].wordmark.grayTop }}</p>
        {% endif %}
        <h1 class="fns-wordmark__main">{{ i18n[lang].wordmark.main }}</h1>
        {% if i18n[lang].wordmark.grayBottom %}
        <p class="fns-wordmark__muted">{{ i18n[lang].wordmark.grayBottom }}</p>
        {% endif %}
      </div>
      <section class="fns-adventure" aria-label="{{ i18n[lang].adventure.ariaLabel }}">
        {% for paragraph in i18n[lang].adventure.paragraphs %}
        <p>{{ paragraph }}</p>
        {% endfor %}
        <p class="fns-adventure__question">{{ i18n[lang].adventure.question }}</p>
        <ul class="fns-adventure__choices">
          {% for choice in i18n[lang].adventure.choices %}
          {% set isExternal = choice.href.indexOf("http://") == 0 or choice.href.indexOf("https://") == 0 %}
          <li>
            <a
              href="{{ choice.href }}"
              {% if isExternal %}rel="noopener noreferrer" target="_blank"{% endif %}
            >{{ choice.label }}</a>
          </li>
          {% endfor %}
        </ul>
      </section>
      <p class="fns-copyright">(c) 2023–2026</p>
    </div>
  </div>
</main>
