{% set currentLang = pageLang or lang or "en" %}
{% set currentMeta = i18n[currentLang].meta %}
{% set metaTitle = pageTitle or currentMeta.title %}
{% set metaDescription = pageDescription or currentMeta.description %}
{% set metaLocale = pageLocale or currentMeta.locale %}
{% set canonicalUrl = site.url ~ (canonicalPath or page.url) %}
{% set xDefaultUrl = site.url ~ (xDefaultPath or "/") %}
<!DOCTYPE html>
<html lang="{{ currentLang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ metaTitle }}</title>
  <meta name="description" content="{{ metaDescription }}">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <meta name="theme-color" content="#1a1f1a">
  <link rel="canonical" href="{{ canonicalUrl }}">
  <link rel="alternate" hreflang="ru" href="{{ site.url }}/ru/">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
  <link rel="alternate" hreflang="x-default" href="{{ xDefaultUrl }}">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ metaTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:locale" content="{{ metaLocale }}">
  <meta property="og:locale:alternate" content="ru_RU">
  <meta property="og:locale:alternate" content="en_US">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ metaTitle }}">
  <meta name="twitter:description" content="{{ metaDescription }}">
  <link rel="preload" href="/assets/fonts/fusion-pixel-12px-proportional-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Tiny5&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}",
      "description": "{{ metaDescription }}",
      "sameAs": [
        "{{ site.social.vk }}",
        "{{ site.social.telegram }}",
        "{{ site.social.max }}"
      ]
    }
  </script>
  <script>
    (function () {
      var SKIES = [
        "sky_01.webp",
        "sky_02.webp",
        "sky_03.webp",
        "sky_04.webp",
        "sky_05.webp",
        "sky_06.webp",
        "sky_07.webp",
        "sky_08.webp",
        "sky_09.webp",
      ];
      var name = SKIES[Math.floor(Math.random() * SKIES.length)];
      document.documentElement.style.setProperty(
        "--fns-bg-sky-image",
        'url("/assets/backgrounds/' + name + '")'
      );
    })();
  </script>
<!-- Yandex.Metrika counter --> <script type="text/javascript">     (function(m,e,t,r,i,k,a){         m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};         m[i].l=1*new Date();         for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}         k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)     })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=108431769', 'ym');      ym(108431769, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true}); </script> <noscript><div><img src="https://mc.yandex.ru/watch/108431769" style="position:absolute; left:-9999px;" alt="" /></div></noscript> <!-- /Yandex.Metrika counter -->
</head>
<body>
  {% if showLanguageNav != false %}
  <nav class="fns-lang" aria-label="{{ i18n[lang].nav.ariaLabel }}">
    <a
      href="/en/"
      hreflang="en"
      title="{{ i18n[lang].nav.en }}"
      aria-label="{{ i18n[lang].nav.en }}"
      {% if lang == "en" %}aria-current="page"{% endif %}
    >{{ i18n[lang].nav.en }}</a>
    <span class="fns-lang-sep" aria-hidden="true">|</span>
    <a
      href="/ru/"
      hreflang="ru"
      title="{{ i18n[lang].nav.ru }}"
      aria-label="{{ i18n[lang].nav.ru }}"
      {% if lang == "ru" %}aria-current="page"{% endif %}
    >{{ i18n[lang].nav.ru }}</a>
  </nav>
  {% endif %}

  {{ content | safe }}
  <script>
    (function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      var SPEEDS = [-1, -0.5, 0, 0.5, 1];
      function pick() {
        return SPEEDS[Math.floor(Math.random() * SPEEDS.length)];
      }

      var sx = pick();
      var sy = pick();
      var rootStyle = getComputedStyle(document.documentElement);
      var tileBase = parseFloat(rootStyle.getPropertyValue("--fns-bg-sky-tile"));
      if (!Number.isFinite(tileBase) || tileBase <= 0) tileBase = 512;
      var tile = tileBase * 2;
      var driftSec = parseFloat(rootStyle.getPropertyValue("--fns-bg-sky-drift"));
      if (!Number.isFinite(driftSec) || driftSec <= 0) driftSec = 120;
      var pxPerSec = tile / driftSec;

      var x = 0;
      var y = 0;
      var last = performance.now();
      var body = document.body;

      function wrap(n) {
        n = n % tile;
        if (n < 0) n += tile;
        return n;
      }

      function tick(now) {
        var dt = Math.min((now - last) / 1000, 0.1);
        last = now;
        x = wrap(x + sx * pxPerSec * dt);
        y = wrap(y + sy * pxPerSec * dt);
        body.style.setProperty("--fns-bg-sky-pos-x", -x + "px");
        body.style.setProperty("--fns-bg-sky-pos-y", -y + "px");
        requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    })();
  </script>
</body>
</html>
